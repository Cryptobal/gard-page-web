{
  "_comment": "Recalibrado 2026-06: el baseline 2026-04 (Perf 0.5, LCP 7000, 1 corrida) quedó al límite del piso real y el gate falló en el 100% de los PRs desde abril por variancia del runner (medido 13-jun: Perf 0.43 y LCP 7155ms en /, LCP 11030ms en /blog sin cambios en esa página). Ahora: 3 corridas con mediana y umbrales al piso observado. A medida que se optimice el sitio, endurecer progresivamente hacia la meta del plan maestro (Perf ≥0.85, LCP ≤2500ms). El gate sigue disparando error si un PR regresa el sitio más allá del piso.",
  "ci": {
    "collect": {
      "startServerCommand": "pnpm run start",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 45000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/empresa-seguridad-privada-chile",
        "http://localhost:3000/mejor-empresa-seguridad-chile",
        "http://localhost:3000/sobre-nosotros",
        "http://localhost:3000/blog"
      ],
      "numberOfRuns": 3,
      "settings": {
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.4, "aggregationMethod": "median" }],
        "categories:seo": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:accessibility": ["warn", { "minScore": 0.85, "aggregationMethod": "median" }],
        "categories:best-practices": ["warn", { "minScore": 0.85, "aggregationMethod": "median" }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 12000, "aggregationMethod": "median" }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1, "aggregationMethod": "median" }],
        "total-blocking-time": ["warn", { "maxNumericValue": 2200, "aggregationMethod": "median" }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
